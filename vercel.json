{
  "rewrites": [
    { "source": "/cert/:no", "destination": "/cert.html" },
    { "source": "/registry", "destination": "/registry.html" },
    { "source": "/claimed", "destination": "/claimed.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "object-src 'none'; base-uri 'none'; frame-ancestors 'none'" }
      ]
    }
  ]
}
